
APP_NAME=LidraFlow
APP_TAGLINE=Omnichannel AI SDR for local B2B
DATABASE_PATH=data/lidraflow.sqlite3

FRONTEND_API_KEY=dev-local-key
FRONTEND_ORIGIN=http://localhost:3000


ADMIN_USER=admin
ADMIN_PASSWORD=change-me-now
DISABLE_WEB_AUTH=false
LIDRAFLOW_AUTH_SECRET=change-this-long-random-auth-secret
AUTH_ALLOW_REGISTRATION=true
AUTH_DEBUG_RESET_TOKENS=true

TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_BOT_ID=PASTE_TELEGRAM_BOT_ID_HERE
ENABLE_BOT_POLLING=true

DEMO_MODE=false
ALLOW_MANUAL_FIRST_CONTACT=false

MAPS_PROVIDER=openstreetmap_overpass
YANDEX_MAPS_API_KEY=PASTE_YANDEX_MAPS_API_KEY_HERE
YANDEX_MAPS_ENDPOINT=https://search-maps.yandex.ru/v1/
OSM_OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
OSM_NOMINATIM_ENDPOINT=https://nominatim.openstreetmap.org/search
MAX_DISCOVERY_LIMIT=50

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
AUTH_COOKIE_SECURE=false
